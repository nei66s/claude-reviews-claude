{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pimpotasma",
  "version": "0.1.0",
  "identifier": "br.com.pimpotasma.app",
  "build": {
    "frontendDist": "https://pimpotasma.com.br",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "Pimpotasma",
        "width": 1200,
        "height": 900
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' https://pimpotasma.com.br; connect-src 'self' https://pimpotasma.com.br ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
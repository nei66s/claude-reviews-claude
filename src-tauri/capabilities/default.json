{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "shell:default",
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "**", "recursive": true }]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "**", "recursive": true }]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "**", "recursive": true }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "**", "recursive": true }]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "cmd-shell",
          "cmd": "cmd",
          "args": ["/C", { "validator": ".*" }]
        },
        {
          "name": "pwsh",
          "cmd": "powershell",
          "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command", { "validator": ".*" }]
        }
      ]
    },
    "shell:allow-open"
  ]
}